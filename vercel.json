{
    "version": 2,
    "builds": [
        {
            "src": "api/main.py",
            "use": "@vercel/python"
        },
        {
            "src": "dashboard/**",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "/api/main.py"
        },
        {
            "src": "/static/(.*)",
            "dest": "/dashboard/$1"
        },
        {
            "src": "/(.*\\.css)",
            "dest": "/dashboard/$1"
        },
        {
            "src": "/(.*\\.js)",
            "dest": "/dashboard/$1"
        },
        {
            "src": "/",
            "dest": "/dashboard/index.html"
        }
    ]
}