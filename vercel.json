{
    "version": 2,
    "builds": [
        {
            "src": "api/main.py",
            "use": "@vercel/python"
        },
        {
            "src": "dashboard/**",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "/api/main.py"
        },
        {
            "src": "/report",
            "dest": "/dashboard/index.html"
        },
        {
            "src": "/(.*\\.css)",
            "dest": "/dashboard/$1"
        },
        {
            "src": "/(.*\\.js)",
            "dest": "/dashboard/$1"
        },
        {
            "src": "/history",
            "dest": "/dashboard/history.html"
        },
        {
            "src": "/",
            "dest": "/dashboard/wizard.html"
        }
    ]
}